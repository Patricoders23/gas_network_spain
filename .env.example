# ============================================================
# gas_network_spain — Environment Variables
# Copy this file to .env and fill in your credentials.
# NEVER commit .env to version control.
# ============================================================

# Anthropic (Claude API)
ANTHROPIC_API_KEY=sk-ant-...

# GIE / AGSI+ API (Gas Infrastructure Europe)
# Register at: https://agsi.gie.eu/account
GIE_API_KEY=

# Telegram bot for alert notifications (optional)
# Create a bot via @BotFather and paste the token here.
TELEGRAM_BOT_TOKEN=

# ---- Optional overrides ----
# LOG_LEVEL=INFO
# DATA_DIR=data
